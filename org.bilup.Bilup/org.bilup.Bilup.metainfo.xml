  <categories>
    <category>Development</category>
  </categories>
  <keywords>
    <keyword>scratch</keyword>
  </keywords>
  <recommends>
    <control>pointing</control>
    <control>keyboard</control>
  </recommends>
  <supports>
    <control>touch</control>
    <!-- gamepad doesn't work in flatpak, the primary user of this file -->
    <!-- <control>gamepad</control> -->
  </supports>
  <content_rating type="oars-1.1">
    <content_attribute id="social-chat">mild</content_attribute>
    <content_attribute id="social-info">mild</content_attribute>
  </content_rating>
  <branding>
    <color type="primary" scheme_preference="light">#75c1c4</color>
    <color type="primary" scheme_preference="dark">#5da8cc</color>
  </branding>

